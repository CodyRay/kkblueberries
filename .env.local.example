# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and should never be committed.

# A random secret used to sign session cookies.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=

# The URL of this app. Use localhost for local dev; set to the live URL in Netlify env vars.
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App credentials.
# Create one at: https://github.com/settings/developers → "New OAuth App"
#   Homepage URL:             https://www.kandkblueberries.com
#   Authorization callback URL: https://www.kandkblueberries.com/api/auth/callback/github
# For local dev, create a second OAuth App with callback: http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=
